// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  educator
  student
}

enum Level {
  Beginner
  Intermediate
  Advanced
}

enum MaterialType {
  Lecture_Slides
  Video
  Quiz
}

enum EnrollmentStatus {
  Pending
  Accepted
  Rejected
}

model User {
  userId           String      @id @default(uuid())
  username     String   @unique @db.VarChar(100)
  email        String   @unique @db.VarChar(150)
  role         Role
  mobileNumber String  @db.VarChar(20)
  profileImage String  @db.Text
  password     String   @db.VarChar(255)
  createdAt    DateTime @default(now())
  courses       Course[] @relation("UserCourses")
  enrollments   Enrollment[] @relation("UserEnrollments")
}

model Course {
  courseId           String      @id @default(uuid())
  title     String   @db.VarChar(100)
  description        String    @db.VarChar(255)
  courseStartDate DateTime 
  courseEndDate DateTime  
  userId String @db.Uuid
  creator User @relation("UserCourses", fields: [userId], references: [userId])
  category     String   @db.VarChar(100)
  level    Level
  materials Material[] @relation("courseMaterials")
  enrollments Enrollment[] @relation("CourseEnrollments")
}

model Material {
  materialId           String      @id @default(uuid())
  courseId String @db.Uuid
  course Course @relation("courseMaterials", fields: [courseId], references: [courseId])
  title     String   @db.VarChar(100)
  description        String    @db.VarChar(255)
  uploadDate DateTime @default(now())  
  URL String? @db.VarChar(500)
  contentType    MaterialType
}

model Enrollment {
  enrollmentId    String           @id @default(uuid())
  userId          String           @db.Uuid
  user            User             @relation("UserEnrollments", fields: [userId], references: [userId])
  courseId        String           @db.Uuid
  course          Course           @relation("CourseEnrollments", fields: [courseId], references: [courseId])
  enrollmentDate  DateTime         @default(now())
  status          EnrollmentStatus @default(Pending)

  @@unique([userId, courseId])
  @@map("enrollments")
}